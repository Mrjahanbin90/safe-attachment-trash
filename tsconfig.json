{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": { "*": ["node_modules/*"] },
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": false
  },
  "include": ["src/**/*.ts"]
}
